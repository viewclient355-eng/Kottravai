{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/(.*).(jpg|jpeg|png|webp|svg|ico|js|css)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": "server/**|config.json",
      "memory": 512,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!api|assets|robots.txt|sitemap.xml|favicon.png|logo.png|.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}